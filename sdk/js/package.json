{
  "name": "@ai-agent/sdk",
  "version": "0.3.0",
  "description": "TypeScript SDK for ai-agent — thin JSON-RPC client + tool helpers",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "ai-agent",
    "sllm",
    "json-rpc",
    "agent",
    "harness"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
