{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ai-agent/docs/schemas/GuardExecuteParams.json",
  "title": "GuardExecuteParams",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "stage"],
  "properties": {
    "name": { "type": "string" },
    "stage": { "type": "string", "enum": ["input", "tool_call", "output"] },
    "input": { "type": "string" },
    "tool_name": { "type": "string" },
    "args": { "type": "object", "description": "Tool arguments when stage is tool_call." },
    "output": { "type": "string" }
  }
}
