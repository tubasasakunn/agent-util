{
  "openrpc": "1.2.6",
  "info": {
    "title": "ai-agent JSON-RPC API",
    "version": "0.1.0",
    "description": "JSON-RPC 2.0 API for the ai-agent SLLM agent harness. The core (Go) and language wrappers communicate over stdio with newline-delimited JSON-RPC. Methods include both wrapper-to-core (request/response) and core-to-wrapper (callbacks). Notifications carry no `id` and expect no response."
  },
  "servers": [
    {
      "name": "stdio",
      "url": "stdio://local",
      "description": "Newline-delimited JSON-RPC 2.0 over stdin/stdout."
    }
  ],
  "methods": [
    {
      "name": "agent.run",
      "summary": "Run the agent loop on a prompt.",
      "description": "Executes the agent loop until completion or until max_turns is reached. Wrapper-to-core request.",
      "params": [
        {
          "name": "params",
          "required": true,
          "schema": { "$ref": "#/components/schemas/AgentRunParams" }
        }
      ],
      "result": {
        "name": "AgentRunResult",
        "schema": { "$ref": "#/components/schemas/AgentRunResult" }
      },
      "errors": [
        { "$ref": "#/components/errors/AgentBusy" },
        { "$ref": "#/components/errors/Aborted" },
        { "$ref": "#/components/errors/Internal" }
      ],
      "examples": [
        {
          "name": "simple-run",
          "params": [
            {
              "name": "params",
              "value": { "prompt": "Summarize README.md", "max_turns": 8 }
            }
          ],
          "result": {
            "name": "AgentRunResult",
            "value": {
              "response": "README.md describes the project.",
              "reason": "completed",
              "turns": 3,
              "usage": { "prompt_tokens": 1234, "completion_tokens": 256, "total_tokens": 1490 }
            }
          }
        }
      ]
    },
    {
      "name": "agent.abort",
      "summary": "Abort the currently running agent loop.",
      "description": "Cancels an in-flight agent.run. Wrapper-to-core request.",
      "params": [
        {
          "name": "params",
          "required": true,
          "schema": { "$ref": "#/components/schemas/AgentAbortParams" }
        }
      ],
      "result": {
        "name": "AgentAbortResult",
        "schema": { "$ref": "#/components/schemas/AgentAbortResult" }
      },
      "errors": [
        { "$ref": "#/components/errors/Internal" }
      ],
      "examples": [
        {
          "name": "abort-with-reason",
          "params": [
            {
              "name": "params",
              "value": { "reason": "user requested" }
            }
          ],
          "result": {
            "name": "AgentAbortResult",
            "value": { "aborted": true }
          }
        }
      ]
    },
    {
      "name": "agent.configure",
      "summary": "Configure the agent harness before agent.run.",
      "description": "Applies harness configuration. Call once before agent.run. nil fields keep existing values; nested config blocks toggle their feature via the `enabled` field.",
      "params": [
        {
          "name": "params",
          "required": true,
          "schema": { "$ref": "#/components/schemas/AgentConfigureParams" }
        }
      ],
      "result": {
        "name": "AgentConfigureResult",
        "schema": { "$ref": "#/components/schemas/AgentConfigureResult" }
      },
      "errors": [
        { "$ref": "#/components/errors/InvalidParams" },
        { "$ref": "#/components/errors/Internal" }
      ],
      "examples": [
        {
          "name": "enable-streaming",
          "params": [
            {
              "name": "params",
              "value": {
                "max_turns": 10,
                "streaming": { "enabled": true, "context_status": true }
              }
            }
          ],
          "result": {
            "name": "AgentConfigureResult",
            "value": { "applied": ["max_turns", "streaming"] }
          }
        }
      ]
    },
    {
      "name": "tool.register",
      "summary": "Register wrapper-implemented tools with the core.",
      "description": "Wrapper-to-core request. Registered tools become invokable from the agent loop and are called back via tool.execute.",
      "params": [
        {
          "name": "params",
          "required": true,
          "schema": { "$ref": "#/components/schemas/ToolRegisterParams" }
        }
      ],
      "result": {
        "name": "ToolRegisterResult",
        "schema": { "$ref": "#/components/schemas/ToolRegisterResult" }
      },
      "errors": [
        { "$ref": "#/components/errors/InvalidParams" }
      ],
      "examples": [
        {
          "name": "register-read-file",
          "params": [
            {
              "name": "params",
              "value": {
                "tools": [
                  {
                    "name": "read_file",
                    "description": "Read a file from the workspace",
                    "parameters": { "type": "object", "properties": { "path": { "type": "string" } }, "required": ["path"] },
                    "read_only": true
                  }
                ]
              }
            }
          ],
          "result": {
            "name": "ToolRegisterResult",
            "value": { "registered": 1 }
          }
        }
      ]
    },
    {
      "name": "tool.execute",
      "summary": "Execute a wrapper-registered tool (core-to-wrapper).",
      "description": "Core-to-wrapper request. The wrapper executes the named tool with the supplied args and returns the textual content (and optional metadata).",
      "params": [
        {
          "name": "params",
          "required": true,
          "schema": { "$ref": "#/components/schemas/ToolExecuteParams" }
        }
      ],
      "result": {
        "name": "ToolExecuteResult",
        "schema": { "$ref": "#/components/schemas/ToolExecuteResult" }
      },
      "errors": [
        { "$ref": "#/components/errors/ToolNotFound" },
        { "$ref": "#/components/errors/ToolExecFailed" }
      ],
      "examples": [
        {
          "name": "execute-read-file",
          "params": [
            {
              "name": "params",
              "value": { "name": "read_file", "args": { "path": "README.md" } }
            }
          ],
          "result": {
            "name": "ToolExecuteResult",
            "value": { "content": "file contents...", "is_error": false }
          }
        }
      ]
    },
    {
      "name": "llm.execute",
      "summary": "Delegate a ChatCompletion to the wrapper (core-to-wrapper).",
      "description": "Reverse RPC. When agent.configure sets llm.mode=\"remote\", every LLM call is forwarded as llm.execute. The wrapper translates the OpenAI-compatible request into any backend format (Anthropic, Bedrock, ollama, mock, ...) and returns an OpenAI-compatible response.",
      "params": [
        {
          "name": "params",
          "required": true,
          "schema": { "$ref": "#/components/schemas/LLMExecuteParams" }
        }
      ],
      "result": {
        "name": "LLMExecuteResult",
        "schema": { "$ref": "#/components/schemas/LLMExecuteResult" }
      },
      "errors": [
        { "$ref": "#/components/errors/Internal" }
      ],
      "examples": [
        {
          "name": "echo-completion",
          "params": [
            {
              "name": "params",
              "value": {
                "request": {
                  "model": "gpt-4o-mini",
                  "messages": [{"role": "user", "content": "hi"}]
                }
              }
            }
          ],
          "result": {
            "name": "LLMExecuteResult",
            "value": {
              "response": {
                "id": "wrapper-1",
                "object": "chat.completion",
                "created": 0,
                "model": "gpt-4o-mini",
                "choices": [{"index": 0, "message": {"role": "assistant", "content": "hello"}, "finish_reason": "stop"}],
                "usage": {"prompt_tokens": 1, "completion_tokens": 1, "total_tokens": 2}
              }
            }
          }
        }
      ]
    },
    {
      "name": "mcp.register",
      "summary": "Register an external MCP server as a tool source.",
      "description": "Wrapper-to-core request. Spawns or connects to the configured MCP server (stdio or sse transport) and exposes its tools to the agent.",
      "params": [
        {
          "name": "params",
          "required": true,
          "schema": { "$ref": "#/components/schemas/MCPRegisterParams" }
        }
      ],
      "result": {
        "name": "MCPRegisterResult",
        "schema": { "$ref": "#/components/schemas/MCPRegisterResult" }
      },
      "errors": [
        { "$ref": "#/components/errors/InvalidParams" },
        { "$ref": "#/components/errors/Internal" }
      ],
      "examples": [
        {
          "name": "stdio-server",
          "params": [
            {
              "name": "params",
              "value": { "transport": "stdio", "command": "mcp-fs", "args": ["--root", "."] }
            }
          ],
          "result": {
            "name": "MCPRegisterResult",
            "value": { "tools": ["fs.read", "fs.write"] }
          }
        }
      ]
    },
    {
      "name": "guard.register",
      "summary": "Register wrapper-implemented guards with the core.",
      "description": "Wrapper-to-core request. Registered guard names can be referenced from agent.configure guards.input/tool_call/output and are invoked via guard.execute.",
      "params": [
        {
          "name": "params",
          "required": true,
          "schema": { "$ref": "#/components/schemas/GuardRegisterParams" }
        }
      ],
      "result": {
        "name": "GuardRegisterResult",
        "schema": { "$ref": "#/components/schemas/GuardRegisterResult" }
      },
      "errors": [
        { "$ref": "#/components/errors/InvalidParams" }
      ],
      "examples": [
        {
          "name": "register-input-guard",
          "params": [
            {
              "name": "params",
              "value": {
                "guards": [
                  { "name": "no_secrets", "stage": "input" }
                ]
              }
            }
          ],
          "result": {
            "name": "GuardRegisterResult",
            "value": { "registered": 1 }
          }
        }
      ]
    },
    {
      "name": "guard.execute",
      "summary": "Execute a wrapper-registered guard (core-to-wrapper).",
      "description": "Core-to-wrapper request. Depending on the stage, either input, tool_name+args, or output is provided.",
      "params": [
        {
          "name": "params",
          "required": true,
          "schema": { "$ref": "#/components/schemas/GuardExecuteParams" }
        }
      ],
      "result": {
        "name": "GuardExecuteResult",
        "schema": { "$ref": "#/components/schemas/GuardExecuteResult" }
      },
      "errors": [
        { "$ref": "#/components/errors/Internal" }
      ],
      "examples": [
        {
          "name": "input-guard-allow",
          "params": [
            {
              "name": "params",
              "value": { "name": "no_secrets", "stage": "input", "input": "hello" }
            }
          ],
          "result": {
            "name": "GuardExecuteResult",
            "value": { "decision": "allow" }
          }
        }
      ]
    },
    {
      "name": "verifier.register",
      "summary": "Register wrapper-implemented verifiers with the core.",
      "description": "Wrapper-to-core request. Registered verifier names can be referenced from agent.configure verify.verifiers and are invoked via verifier.execute.",
      "params": [
        {
          "name": "params",
          "required": true,
          "schema": { "$ref": "#/components/schemas/VerifierRegisterParams" }
        }
      ],
      "result": {
        "name": "VerifierRegisterResult",
        "schema": { "$ref": "#/components/schemas/VerifierRegisterResult" }
      },
      "errors": [
        { "$ref": "#/components/errors/InvalidParams" }
      ],
      "examples": [
        {
          "name": "register-verifier",
          "params": [
            {
              "name": "params",
              "value": { "verifiers": [{ "name": "json_valid" }] }
            }
          ],
          "result": {
            "name": "VerifierRegisterResult",
            "value": { "registered": 1 }
          }
        }
      ]
    },
    {
      "name": "verifier.execute",
      "summary": "Execute a wrapper-registered verifier (core-to-wrapper).",
      "description": "Core-to-wrapper request. Verifies the result of a tool invocation.",
      "params": [
        {
          "name": "params",
          "required": true,
          "schema": { "$ref": "#/components/schemas/VerifierExecuteParams" }
        }
      ],
      "result": {
        "name": "VerifierExecuteResult",
        "schema": { "$ref": "#/components/schemas/VerifierExecuteResult" }
      },
      "errors": [
        { "$ref": "#/components/errors/Internal" }
      ],
      "examples": [
        {
          "name": "verify-passed",
          "params": [
            {
              "name": "params",
              "value": { "name": "json_valid", "tool_name": "fetch_json", "result": "{\"ok\":true}" }
            }
          ],
          "result": {
            "name": "VerifierExecuteResult",
            "value": { "passed": true }
          }
        }
      ]
    },
    {
      "name": "stream.delta",
      "summary": "Notification: streaming text delta from the model (core-to-wrapper).",
      "description": "Sent as a JSON-RPC notification (no id). Carries an incremental text chunk produced by the model. Result is null per OpenRPC notification convention.",
      "paramStructure": "by-name",
      "params": [
        {
          "name": "params",
          "required": true,
          "schema": { "$ref": "#/components/schemas/StreamDeltaParams" }
        }
      ],
      "result": {
        "name": "null",
        "schema": { "type": "null" }
      },
      "examples": [
        {
          "name": "delta-chunk",
          "params": [
            {
              "name": "params",
              "value": { "text": "Hello", "turn": 1 }
            }
          ],
          "result": { "name": "null", "value": null }
        }
      ]
    },
    {
      "name": "stream.end",
      "summary": "Notification: streaming complete (core-to-wrapper).",
      "description": "Sent as a JSON-RPC notification (no id). Indicates the agent loop has finished. Result is null per OpenRPC notification convention.",
      "paramStructure": "by-name",
      "params": [
        {
          "name": "params",
          "required": true,
          "schema": { "$ref": "#/components/schemas/StreamEndParams" }
        }
      ],
      "result": {
        "name": "null",
        "schema": { "type": "null" }
      },
      "examples": [
        {
          "name": "end-completed",
          "params": [
            {
              "name": "params",
              "value": { "reason": "completed", "turns": 3 }
            }
          ],
          "result": { "name": "null", "value": null }
        }
      ]
    },
    {
      "name": "context.status",
      "summary": "Notification: context window usage (core-to-wrapper).",
      "description": "Sent as a JSON-RPC notification (no id). Reports current context window usage. Result is null per OpenRPC notification convention.",
      "paramStructure": "by-name",
      "params": [
        {
          "name": "params",
          "required": true,
          "schema": { "$ref": "#/components/schemas/ContextStatusParams" }
        }
      ],
      "result": {
        "name": "null",
        "schema": { "type": "null" }
      },
      "examples": [
        {
          "name": "half-full",
          "params": [
            {
              "name": "params",
              "value": { "usage_ratio": 0.5, "token_count": 2048, "token_limit": 4096 }
            }
          ],
          "result": { "name": "null", "value": null }
        }
      ]
    },
    {
      "name": "judge.register",
      "summary": "Register a goal judge (wrapper-to-core).",
      "description": "Registers a named goal judge implemented in the wrapper. The name can then be referenced in agent.configure judge.name. The core will call judge.evaluate on this wrapper when goal judgment is needed.",
      "paramStructure": "by-name",
      "params": [
        {
          "name": "params",
          "required": true,
          "schema": { "$ref": "#/components/schemas/JudgeRegisterParams" }
        }
      ],
      "result": {
        "name": "result",
        "schema": { "$ref": "#/components/schemas/JudgeRegisterResult" }
      },
      "examples": [
        {
          "name": "register-goal-judge",
          "params": [
            {
              "name": "params",
              "value": { "name": "my_judge" }
            }
          ],
          "result": { "name": "result", "value": { "registered": 1 } }
        }
      ]
    },
    {
      "name": "judge.evaluate",
      "summary": "Request goal judgment (core-to-wrapper).",
      "description": "Called by the core after each 'completed' terminal result to ask the wrapper whether the goal has been achieved. The wrapper returns terminate=true to stop the loop, or false to continue.",
      "paramStructure": "by-name",
      "params": [
        {
          "name": "params",
          "required": true,
          "schema": { "$ref": "#/components/schemas/JudgeEvaluateParams" }
        }
      ],
      "result": {
        "name": "result",
        "schema": { "$ref": "#/components/schemas/JudgeEvaluateResult" }
      },
      "examples": [
        {
          "name": "goal-reached",
          "params": [
            {
              "name": "params",
              "value": { "name": "my_judge", "response": "Task complete.", "turn": 3 }
            }
          ],
          "result": { "name": "result", "value": { "terminate": true, "reason": "goal_reached" } }
        }
      ]
    }
  ],
  "components": {
    "errors": {
      "Parse": { "code": -32700, "message": "Parse error" },
      "InvalidRequest": { "code": -32600, "message": "Invalid request" },
      "MethodNotFound": { "code": -32601, "message": "Method not found" },
      "InvalidParams": { "code": -32602, "message": "Invalid params" },
      "Internal": { "code": -32603, "message": "Internal error" },
      "ToolNotFound": { "code": -32000, "message": "Tool not found" },
      "ToolExecFailed": { "code": -32001, "message": "Tool execution failed" },
      "AgentBusy": { "code": -32002, "message": "Agent already running" },
      "Aborted": { "code": -32003, "message": "Aborted" },
      "MessageTooLarge": { "code": -32004, "message": "Message too large" }
    },
    "schemas": {
      "AgentRunParams": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "https://github.com/ai-agent/docs/schemas/AgentRunParams.json",
        "title": "AgentRunParams",
        "type": "object",
        "additionalProperties": false,
        "required": ["prompt"],
        "properties": {
          "prompt": { "type": "string" },
          "max_turns": { "type": "integer" }
        }
      },
      "AgentRunResult": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "https://github.com/ai-agent/docs/schemas/AgentRunResult.json",
        "title": "AgentRunResult",
        "type": "object",
        "additionalProperties": false,
        "required": ["response", "reason", "turns", "usage"],
        "properties": {
          "response": { "type": "string" },
          "reason": { "type": "string" },
          "turns": { "type": "integer" },
          "usage": { "$ref": "#/components/schemas/UsageInfo" }
        }
      },
      "UsageInfo": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "https://github.com/ai-agent/docs/schemas/UsageInfo.json",
        "title": "UsageInfo",
        "type": "object",
        "additionalProperties": false,
        "required": ["prompt_tokens", "completion_tokens", "total_tokens"],
        "properties": {
          "prompt_tokens": { "type": "integer" },
          "completion_tokens": { "type": "integer" },
          "total_tokens": { "type": "integer" }
        }
      },
      "AgentAbortParams": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "https://github.com/ai-agent/docs/schemas/AgentAbortParams.json",
        "title": "AgentAbortParams",
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "reason": { "type": "string" }
        }
      },
      "AgentAbortResult": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "https://github.com/ai-agent/docs/schemas/AgentAbortResult.json",
        "title": "AgentAbortResult",
        "type": "object",
        "additionalProperties": false,
        "required": ["aborted"],
        "properties": {
          "aborted": { "type": "boolean" }
        }
      },
      "AgentConfigureParams": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "https://github.com/ai-agent/docs/schemas/AgentConfigureParams.json",
        "title": "AgentConfigureParams",
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "max_turns": { "type": "integer" },
          "system_prompt": { "type": "string" },
          "token_limit": { "type": "integer" },
          "work_dir": { "type": "string" },
          "delegate": { "$ref": "#/components/schemas/DelegateConfig" },
          "coordinator": { "$ref": "#/components/schemas/CoordinatorConfig" },
          "compaction": { "$ref": "#/components/schemas/CompactionConfig" },
          "permission": { "$ref": "#/components/schemas/PermissionConfig" },
          "guards": { "$ref": "#/components/schemas/GuardsConfig" },
          "verify": { "$ref": "#/components/schemas/VerifyConfig" },
          "tool_scope": { "$ref": "#/components/schemas/ToolScopeConfig" },
          "reminder": { "$ref": "#/components/schemas/ReminderConfig" },
          "streaming": { "$ref": "#/components/schemas/StreamingConfig" },
          "loop": { "$ref": "#/components/schemas/LoopConfig" },
          "router": { "$ref": "#/components/schemas/RouterConfig" },
          "judge": { "$ref": "#/components/schemas/JudgeConfig" },
          "llm": { "$ref": "#/components/schemas/LLMConfig" }
        }
      },
      "LLMConfig": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "https://github.com/ai-agent/docs/schemas/LLMConfig.json",
        "title": "LLMConfig",
        "description": "Main LLM driver settings. mode=\"remote\" delegates ChatCompletion to the wrapper via llm.execute.",
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "mode": {
            "type": "string",
            "enum": ["http", "remote"]
          },
          "timeout_seconds": { "type": "integer", "minimum": 0 }
        }
      },
      "LLMExecuteParams": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "https://github.com/ai-agent/docs/schemas/LLMExecuteParams.json",
        "title": "LLMExecuteParams",
        "description": "Reverse RPC params (core -> wrapper).",
        "type": "object",
        "additionalProperties": false,
        "required": ["request"],
        "properties": {
          "request": {
            "type": "object",
            "additionalProperties": true,
            "description": "Opaque OpenAI-compatible ChatRequest."
          },
          "session_id": {
            "type": "string",
            "description": "Stable session identifier for wrapper-side KV cache (E2)."
          },
          "call_index": {
            "type": "integer",
            "description": "Sequential index of this llm.execute within a single agent.run."
          }
        }
      },
      "LLMExecuteResult": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "https://github.com/ai-agent/docs/schemas/LLMExecuteResult.json",
        "title": "LLMExecuteResult",
        "description": "Reverse RPC result (wrapper -> core).",
        "type": "object",
        "additionalProperties": false,
        "required": ["response"],
        "properties": {
          "response": {
            "type": "object",
            "additionalProperties": true,
            "description": "Opaque OpenAI-compatible ChatResponse."
          }
        }
      },
      "DelegateConfig": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "https://github.com/ai-agent/docs/schemas/DelegateConfig.json",
        "title": "DelegateConfig",
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean" },
          "max_chars": { "type": "integer" }
        }
      },
      "CoordinatorConfig": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "https://github.com/ai-agent/docs/schemas/CoordinatorConfig.json",
        "title": "CoordinatorConfig",
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean" },
          "max_chars": { "type": "integer" }
        }
      },
      "CompactionConfig": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "https://github.com/ai-agent/docs/schemas/CompactionConfig.json",
        "title": "CompactionConfig",
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean" },
          "budget_max_chars": { "type": "integer" },
          "keep_last": { "type": "integer" },
